# ============================================================
# CONTOH file environment variables.
# Salin file ini menjadi ".env" lalu isi nilainya.
# JANGAN pernah upload file .env asli ke GitHub (sudah diblok .gitignore).
# ============================================================

# Token bot Telegram dari @BotFather. Contoh format:
TELEGRAM_TOKEN=123456789:AAExampleabcdefGHIjklMNOpqrSTUvwxyz

# ID tujuan. Bisa lebih dari satu, pisahkan koma.
# Contoh: chat pribadi 12345678, grup -1001234567890
TELEGRAM_CHAT_IDS=12345678

# "once" = jalan 1x lalu berhenti (untuk GitHub Actions / cron)
# "loop" = jalan terus-menerus (untuk Railway / laptop)
RUN_MODE=once

# Hanya untuk mode loop: ulang tiap berapa menit
CHECK_INTERVAL_MINUTES=60

# Ambang skor minimum agar sebuah berita dikirim (4-6 disarankan)
MIN_SCORE_TO_ALERT=4

# Jam (WIB, 0-23) untuk ringkasan harian. Isi -1 untuk mematikan.
DAILY_SUMMARY_HOUR=7
